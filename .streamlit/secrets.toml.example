# 사용법: 이 파일을 복사해 같은 폴더에 `secrets.toml` 로 저장하고 실제 값을 채우세요.
# (.streamlit/secrets.toml 은 .gitignore 처리됨 — 절대 GitHub에 올리지 마세요)
# Render 배포 시에는 Render의 'Secret Files'에 파일명 `.streamlit/secrets.toml` 로 같은 내용을 넣습니다.

# Google 로그인 (Streamlit 공식 st.login — 단일 provider 형식)
# redirect_uri = 배포 주소 + /oauth2callback. 구글 OAuth 클라이언트의 '승인된 리디렉션 URI'에도 동일 등록.
#   - 로컬:  http://localhost:8501/oauth2callback
#   - Render: https://<앱이름>.onrender.com/oauth2callback
# cookie_secret 생성: python -c "import secrets;print(secrets.token_hex(32))"
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "여기에_랜덤_64자_hex_문자열_넣기"
client_id = "여기에_구글_OAuth_클라이언트_ID_붙여넣기"
client_secret = "여기에_구글_OAuth_클라이언트_Secret_붙여넣기"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# 관심종목 저장용 Supabase (Project Settings → API 에서 복사)
[supabase]
url = "https://여기에_프로젝트.supabase.co"
key = "여기에_anon_또는_publishable_key_붙여넣기"
